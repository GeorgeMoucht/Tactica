cat > .gitignore <<'GIT'
bin/
obj/
.vs/
.idea/
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
.DS_Store
Logs/
*.log
TestResults/
BenchmarkDotNet.Artifacts/
appsettings.*.local.json
GIT

cat > global.json <<'JSON'
{
  "sdk": { "version": "8.0.302", "rollForward": "latestFeature" }
}
JSON
